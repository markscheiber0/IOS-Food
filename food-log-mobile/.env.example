# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
# Note: SUPABASE_URL and SUPABASE_ANON_KEY are safe to embed in the app binary
# (RLS is the security boundary) but live here so the repo stays key-free.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Apple Developer team ID (Xcode → Settings → Accounts, or developer.apple.com → Membership)
APPLE_TEAM_ID=XXXXXXXXXX

# iCloud share link for the published "Log Food" shortcut (see docs/SIRI_SHORTCUT.md)
SIRI_SHORTCUT_URL=https://www.icloud.com/shortcuts/your-shortcut-id
